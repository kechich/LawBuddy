# Supabase — copy this file to .env and fill in your project's values.
# These VITE_ variables are exposed to the browser bundle by design.
# Use only the public "anon" / publishable key here (never a service_role key).

VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
